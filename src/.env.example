# ============================================================
# API Keys for Business Idea Validator Agent System
# ============================================================
# Copy this file to .env and fill in your actual API keys

# ============================================================
# OpenAI API Configuration (必需)
# ============================================================
OPENAI_API_KEY=""

# OpenAI Base URL (可选)
# 默认: https://api.openai.com/v1
# 如使用代理，修改为代理地址
OPENAI_BASE_URL=""

# ============================================================
# TikHub API Configuration (必需)
# ============================================================
# 获取方式: https://www.tikhub.io/
# 用于小红书数据抓取
TIKHUB_TOKEN=""

# ============================================================
# 系统配置 (可选)
# ============================================================

# 每个关键词搜索的页数（默认: 2）
SCRAPER_PAGES_PER_KEYWORD=2

# 每个笔记获取的评论数（默认: 20）
SCRAPER_COMMENTS_PER_NOTE=10

# 最大笔记分析数（默认: 20）
ANALYZER_MAX_POSTS=30

# 报告输出目录（默认: reports）
REPORT_OUTPUT_DIR=reports
